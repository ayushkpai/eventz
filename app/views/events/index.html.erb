<% @events.each do |event| %>
  <section class="event">
    <div class="summary">
      <h2><%= link_to event.name, event %></h2>
      <h3><p><%= day_and_time(event) %> in <%= event.location %></p></h3>
      <span class="price"><%= price(event) %></span>
      <p><%= truncate(event.description, length: 35, separator: " ") %></p>
    </div>
  </section>
<% end %>

<section class="admin"><%= link_to "Add Event", new_event_path, class: "btn btn-secondary" %></section>
